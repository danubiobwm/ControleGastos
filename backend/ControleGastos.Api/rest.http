@baseUrl = http://localhost:5000/api

# ==========================================================
# --- CADASTRO DE PESSOAS ---
# ==========================================================

### 1. Criar Pessoa (Maior de Idade)
# @name criarPessoaMaior
POST {{baseUrl}}/pessoas
Content-Type: application/json

{
  "nome": "João Silva",
  "idade": 30
}

### 2. Criar Pessoa (Menor de Idade)
# @name criarPessoaMenor
POST {{baseUrl}}/pessoas
Content-Type: application/json

{
  "nome": "Joaquim Filho",
  "idade": 14
}

### 3. Listar Todas as Pessoas
GET {{baseUrl}}/pessoas
Accept: application/json

### 4. Editar Pessoa
# Substitua o ID pelo ID real gerado no banco
PUT {{baseUrl}}/pessoas/ID_AQUI
Content-Type: application/json

{
  "nome": "João Silva Alterado",
  "idade": 31
}

### 5. Deletar Pessoa
DELETE {{baseUrl}}/pessoas/ID_AQUI


# ==========================================================
# --- CADASTRO DE CATEGORIAS ---
# ==========================================================

### 6. Criar Categoria (Receita)
# @name criarCategoriaReceita
POST {{baseUrl}}/categorias
Content-Type: application/json

{
  "descricao": "Salário Mensal",
  "finalidade": "receita"
}

### 7. Criar Categoria (Despesa)
POST {{baseUrl}}/categorias
Content-Type: application/json

{
  "descricao": "Aluguel",
  "finalidade": "despesa"
}

### 8. Listar Categorias
GET {{baseUrl}}/categorias
Accept: application/json

### 9. Editar Categoria (NOVO)
PUT {{baseUrl}}/categorias/ID_AQUI
Content-Type: application/json

{
  "descricao": "Salário e Bônus",
  "finalidade": "receita"
}

### 10. Deletar Categoria (NOVO)
DELETE {{baseUrl}}/categorias/ID_AQUI


# ==========================================================
# --- CADASTRO DE TRANSAÇÕES (COM REGRAS) ---
# ==========================================================

### 11. Criar Transação Válida
POST {{baseUrl}}/transacoes
Content-Type: application/json

{
  "descricao": "Venda de Notebook",
  "valor": 2500.00,
  "tipo": "receita",
  "categoriaId": "ID_DA_CATEGORIA",
  "pessoaId": "ID_DA_PESSOA"
}

### 12. TESTE DE ERRO: Receita para Menor (Deve retornar 400)
POST {{baseUrl}}/transacoes
Content-Type: application/json

{
  "descricao": "Mesada",
  "valor": 50.00,
  "tipo": "receita",
  "categoriaId": "ID_DA_CATEGORIA",
  "pessoaId": "ID_DO_PEDRO_FILHO"
}

### 13. Listar Todas as Transações
GET {{baseUrl}}/transacoes
Accept: application/json


# ==========================================================
# --- CONSULTAS DE TOTAIS (RELATÓRIOS) ---
# ==========================================================

### 14. Consulta de Totais por Pessoa (Dashboard)
GET {{baseUrl}}/pessoas/totais
Accept: application/json

### 15. Consulta de Totais por Categoria
GET {{baseUrl}}/categorias/totais
Accept: application/json